# OpenRouter API key (never commit real values)
# Recommended: copy this file from github/ to ../private/.env (see ../private/README.md); a file named .env at the workspace root also works.
OPENROUTER_API_KEY=your-openrouter-key-here

# Chat models (OpenRouter IDs) — defaults match load_config if unset
PRMP_CHAT_MODEL_A=google/gemini-3.5-flash
PRMP_CHAT_MODEL_B=meta-llama/llama-3.3-70b-instruct

# Single embedding model for the observer E
PRMP_EMBEDDING_MODEL=openai/text-embedding-3-small

# Pipeline dimensions / windows
PRMP_MANIFOLD=pca
PRMP_UMAP_N_NEIGHBORS=5
PRMP_UMAP_MIN_DIST=0.1
PRMP_UMAP_METRIC=euclidean
PRMP_UMAP_MIN_SAMPLES=8

PRMP_R_SPEC_METHOD=svd_proxy
PRMP_EDMD_RANK=8

PRMP_PCA_K=16
PRMP_DMD_WINDOW=8
PRMP_GRASSMANN_W=7
PRMP_GRASSMANN_R=3
PRMP_TDA_WINDOW=7

PRMP_STABILITY_WINDOW=5
PRMP_CSD_VARIANCE_WINDOW=5
PRMP_UNITY_GAMMA_NORM=1.35
PRMP_UNITY_W_P_NORM=0.65
PRMP_CSD_VARIANCE_MULT=2.0

# Session limits
PRMP_MAX_STEPS=12
PRMP_MAX_TOKENS=512
PRMP_TEMPERATURE=0.4

# Template for h(observable text sent to embeddings), placeholders: {agent},{action_id},{rationale}
PRMP_H_TEMPLATE={agent}:{action_id}:{rationale}

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=
